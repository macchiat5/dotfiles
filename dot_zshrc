# PATH
export PATH="$HOME/.local/bin:$PATH"
export PATH="$PATH:/opt/nvim-linux-x86_64/bin"

# GoPath
export GOPATH=$HOME/.local/share/go

# zsh 자동완성 초기화 (플러그인 로드 전에)
autoload -Uz compinit
compinit

# autosuggestions 설정 (플러그인 로드 전에)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=1
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# 플러그인
source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
source ~/.zsh/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

# 히스토리
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt share_history
setopt hist_ignore_dups

# 유용한 옵션
setopt auto_cd
setopt correct

# flow control 
stty -ixon 

# alias
alias fd='fdfind'
alias l='eza --icons'
alias ll='eza -lah --icons'
alias lt='eza --tree --icons'
alias cat='bat --paging=never'
alias grep='grep --color=auto'
alias v='nvim'
alias g='lazygit'
alias y='yazi_cd'
alias e='exit'
alias c='clear'
alias config='nvim ~/.zshrc'
alias src='source ~/.zshrc'
alias ta='tmux attach'

# yazi에서 나올 때 해당 디렉토리로 이동
function yazi_cd() {
    local tmp="$(mktemp -t yazi-cwd.XXXXXX)"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

# zoxide
eval "$(zoxide init zsh)"

# fzf
source /usr/share/doc/fzf/examples/key-bindings.zsh
source /usr/share/doc/fzf/examples/completion.zsh

# mise
eval "$(mise activate zsh)"

# Rust
source ~/.cargo/env

# 환경변수
export GSK_RENDERER=cairo

# Starship 프롬프트 (항상 마지막에)
eval "$(starship init zsh)"

# dotfiles managements for chezmoi
alias dots='cd ~/.local/share/chezmoi && git add . && git commit -m "Update dotfiles" && git push'
